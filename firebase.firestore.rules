rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Posts
    match /posts/{postId} {
      allow read: if true; // public

      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.brand is string
        && request.resource.data.intention is string
        && request.resource.data.side is string
        && request.resource.data.createdAt == request.time
        && request.resource.data.userDisplayName is string;

      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Post reactions (likes/dislikes)
    match /posts/{postId}/reactions/{userId} {
      allow read: if true; // public
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Reports (not publicly readable)
    match /reports/{reportId} {
      allow read: if false; // hide reports by default
      allow create: if request.auth != null
        && request.resource.data.postId is string
        && request.resource.data.reason is string
        && request.resource.data.createdAt == request.time;
    }

    // Optional user profiles (if used)
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
