{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "predeploy": [
      "npm ci",
      "npm run build"
    ]
  },
  "storage": {
    "rules": "firebase.storage.rules"
  },
  "firestore": {
    "rules": "firebase.firestore.rules"
  }
}
