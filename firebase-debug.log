[debug] [2025-08-10T16:59:12.886Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/earpieces-e9378/rulesets {"name":"projects/earpieces-e9378/rulesets/c2c6baa4-a6a6-42fd-ab5a-b5a67be0dbd8","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Posts\n    match /posts/{postId} {\n      allow read: if true; // public\n\n      allow create: if request.auth != null\n        && request.resource.data.userId == request.auth.uid\n        && request.resource.data.brand is string\n        && request.resource.data.intention is string\n        && request.resource.data.side is string\n        && request.resource.data.createdAt == request.time\n        && request.resource.data.userDisplayName is string;\n\n      allow update, delete: if request.auth != null\n        && resource.data.userId == request.auth.uid;\n    }\n\n    // Post reactions (likes/dislikes)\n    match /posts/{postId}/reactions/{userId} {\n      allow read: if true; // public\n      allow write: if request.auth != null && request.auth.uid == userId;\n    }\n\n    // Reports (not publicly readable)\n    match /reports/{reportId} {\n      allow read: if false; // hide reports by default\n      allow create: if request.auth != null\n        && request.resource.data.postId is string\n        && request.resource.data.reason is string\n        && request.resource.data.createdAt == request.time;\n    }\n\n    // Optional user profiles (if used)\n    match /users/{uid} {\n      allow read: if true;\n      allow write: if request.auth != null && request.auth.uid == uid;\n    }\n  }\n}\n","name":"firebase.firestore.rules"}]},"createTime":"2025-08-10T16:59:12.796095Z","metadata":{"services":["cloud.firestore"]}}
